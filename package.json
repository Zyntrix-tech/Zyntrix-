{
  "name": "zyntrix-whatsapp-bot",
  "version": "1.0.0",
  "description": "Zyntrix WhatsApp Bot - Telegram Bot Manager for WhatsApp Connections",
  "main": "bot.js",
  "scripts": {
    "start": "node healthcheck.js",
    "bot": "node bot.js",
    "bot:win": "node bot.js",
    "clean:auth": "node -e \"require('fs').rmSync('backend/bots/auth_info',{recursive:true,force:true});console.log('auth_info cleaned')\"",
